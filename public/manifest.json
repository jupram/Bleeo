{
  "manifest_version": 3,
  "name": "Bleeo",
  "description": "Blur sensationalized text on news and social sites to protect your mental space.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": [
    "*://cnn.com/*",
    "*://*.cnn.com/*",
    "*://bbc.com/*",
    "*://*.bbc.com/*",
    "*://nytimes.com/*",
    "*://*.nytimes.com/*",
    "*://foxnews.com/*",
    "*://*.foxnews.com/*",
    "*://nypost.com/*",
    "*://*.nypost.com/*",
    "*://theguardian.com/*",
    "*://*.theguardian.com/*",
    "*://washingtonpost.com/*",
    "*://*.washingtonpost.com/*",
    "*://news.google.com/*",
    "*://*.news.google.com/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://youtube.com/*",
    "*://*.youtube.com/*",
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://threads.net/*",
    "*://*.threads.net/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://cnn.com/*",
        "*://*.cnn.com/*",
        "*://bbc.com/*",
        "*://*.bbc.com/*",
        "*://nytimes.com/*",
        "*://*.nytimes.com/*",
        "*://foxnews.com/*",
        "*://*.foxnews.com/*",
        "*://nypost.com/*",
        "*://*.nypost.com/*",
        "*://theguardian.com/*",
        "*://*.theguardian.com/*",
        "*://washingtonpost.com/*",
        "*://*.washingtonpost.com/*",
        "*://news.google.com/*",
        "*://*.news.google.com/*",
        "*://reddit.com/*",
        "*://*.reddit.com/*",
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*",
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://facebook.com/*",
        "*://*.facebook.com/*",
        "*://instagram.com/*",
        "*://*.instagram.com/*",
        "*://threads.net/*",
        "*://*.threads.net/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Bleeo",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
